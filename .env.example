# Claude IDE environment template. Copy to .env (gitignored) only if needed.
#
# The IDE stores NO credentials and sets no API keys — it rides the Claude Code
# CLI's own auth (spec 2.8, 3.10). These are optional developer overrides.

# Backend log verbosity (tracing EnvFilter). Default: info,claude_ide_lib=debug
# RUST_LOG=debug

# Override the Claude Code config home for testing. NOTE: this relocates the
# ENTIRE config home (auth + settings + MCP) — do not use for per-workspace
# isolation (spec 3.10). Isolate by cwd instead.
# CLAUDE_CONFIG_DIR=
